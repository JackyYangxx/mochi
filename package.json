{
  "name": "mochi",
  "version": "1.0.27",
  "description": "Mochi — 桌面宠物形态的 AI 智能待办助手，支持语音输入、快捷键添加、智能提醒与本地知识库。",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "electron dist/main/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "lint": "eslint src/ src-renderer/ tests/",
    "format": "prettier --write src/ src-renderer/ tests/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.1",
  "dependencies": {
    "animejs": "^4.4.1",
    "better-sqlite3": "9.6.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.4.4",
    "node-fetch": "^2.7.0",
    "openai": "4.77.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tr46": "^5.0.0",
    "uuid": "^9.0.1",
    "webidl-conversions": "^7.0.0",
    "zod": "3.23.8",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gifenc": "^1.0.3",
    "jsdom": "^23.2.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
